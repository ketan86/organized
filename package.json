{
  "name": "organized",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:migrate && next dev -p 8080",
    "build": "npm run db:migrate && next build",
    "start": "next start -p 8080",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "vapid:generate": "tsx scripts/generate-vapid.ts",
    "reminders:watch": "tsx --env-file=.env.local scripts/reminders-watch.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/openai": "^4.0.8",
    "@libsql/client": "^0.17.4",
    "ai": "^7.0.16",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
