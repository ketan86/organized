# AI provider: google (default) | openai
AI_PROVIDER=google

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Free tier: gemini-2.5-flash-lite (highest limits) or gemini-2.5-flash
GOOGLE_MODEL=gemini-2.5-flash-lite

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database — local dev uses file SQLite; production uses Turso
# DATABASE_URL=./data/organized.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Web Push (optional — in-app reminders work without these)
# Generate with: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secures /api/cron/reminders (use with cron-job.org or similar on Vercel Hobby)
CRON_SECRET=
